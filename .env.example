# Copy to `.env` (which is gitignored) and fill in real values. Never commit secrets.

# Pinata (IPFS pinning) — used by `node build/publish-ipfs.js`.
# The JWT is the one that works with the v3 uploads API (uploads.pinata.cloud/v3/files).
# NOTE: PINATA_JWT is baked into the built bundle at build time, so it is publicly
# extractable from dist/app.js — use a scoped, rotatable key.
PINATA_JWT=

# Legacy Pinata key/secret (v2 API). Optional; the JWT above is preferred.
PINATA_API_KEY=
PINATA_SECRET_API_KEY=

# Bendystraw indexer API key — baked into the bundle for cross-chain reads.
BENDYSTRAW_API_KEY=

# Build input: path to the deploy-all-v6 `deployments/` dir, read at bundle time
# to generate the contract address manifest.
DEPLOY_ALL_DEPLOYMENTS_DIR=
