  "devdoc": {
    "allSuckersOf(uint256)": {
      "details": "Used by consumers that need to detect \"has any sucker ever peered to chain X?\" — e.g. to prevent premature burn of bridgeable credit by `JBReferralSplitHook.burnUnbridgeableCreditFor`. Returns every key from `_suckersOf[projectId]` regardless of active/deprecated state. Order matches the underlying `EnumerableMap` iteration order (insertion order, with swap-and-pop semantics on removal — which this registry doesn't trigger, since deprecation transitions to `_SUCKER_DEPRECATED` rather than deleting).",
      "params": {
        "projectId": "The ID of the project to get the suckers of."
      },
      "returns": {
        "suckers": "The addresses of every sucker ever registered for `projectId`."
      }
    },
    "allowSuckerDeployer(address)": {
      "details": "Can only be called by this contract's owner (initially project ID 1, or JuiceboxDAO).",
      "params": {
        "deployer": "The address of the deployer to add."
      }
    },
    "allowSuckerDeployers(address[])": {
      "details": "Can only be called by this contract's owner (initially project ID 1, or JuiceboxDAO).",
      "params": {
        "deployers": "The addresses of the deployers to add."
      }
    },
    "constructor": {
      "params": {
        "directory": "The juicebox directory.",
        "initialOwner": "The initial owner of this contract.",
        "permissions": "A contract storing permissions.",
        "prices": "The prices contract used to value remote per-context surplus/balance into a requested currency."
      }
    },
    "deploySuckersFor(uint256,bytes32,(address,bytes32,(address,uint32,bytes32)[])[])": {
      "params": {
        "configurations": "The sucker deployer configs to use to deploy the suckers.",
        "projectId": "The ID of the project to deploy suckers for.",
        "salt": "The salt used to deploy the contract. For the suckers to be peers, this must be the same value on each chain where suckers are deployed."
      },
      "returns": {
        "suckers": "The addresses of the deployed suckers."
      }
    },
    "isSuckerOf(uint256,address)": {
      "params": {
        "addr": "The address of the sucker to check.",
        "projectId": "The ID of the project to check for."
      },
      "returns": {
        "_0": "flag A flag indicating if the sucker belongs to the project, and was deployed through this registry."
      }
    },
    "isTrustedForwarder(address)": {
      "details": "Indicates whether any particular address is the trusted forwarder."
    },
    "owner()": {
      "details": "Returns the address of the current owner."
    },
    "remoteBalanceOf(address,uint256,uint256,uint256)": {
      "details": "Exposed as an external self-call boundary so `totalRemoteBalanceOf` can `try` it and drop a single sucker whose price feed is missing. A context whose currency already matches `currency` folds in at par (no feed read); a missing cross-currency feed reverts, and the aggregator catches it and skips just this sucker.",
      "params": {
        "currency": "The currency to value into.",
        "decimals": "The decimal precision for the returned value.",
        "projectId": "The project whose price feeds to use.",
        "sucker": "The sucker to read."
      },
      "returns": {
        "_0": "A `JBPeerChainValue` with the valued balance, the sucker's peer chain ID, and its snapshot freshness key."
      }
    },
    "remoteSurplusOf(address,uint256,uint256,uint256)": {
      "details": "Exposed as an external self-call boundary so `totalRemoteSurplusOf` can `try` it and drop a single sucker whose price feed is missing. A context whose currency already matches `currency` folds in at par (no feed read); a missing cross-currency feed reverts, and the aggregator catches it and skips just this sucker.",
      "params": {
        "currency": "The currency to value into.",
        "decimals": "The decimal precision for the returned value.",
        "projectId": "The project whose price feeds to use.",
        "sucker": "The sucker to read."
      },
      "returns": {
        "_0": "A `JBPeerChainValue` with the valued surplus, the sucker's peer chain ID, and its snapshot freshness key."
      }
    },
    "remoteTotalSupplyOf(uint256)": {
      "details": "Includes deprecated suckers only when no active sucker answers for the same peer chain, to prevent undercounting during migration windows without letting stale deprecated snapshots dominate live routes. Silently skips suckers that revert.",
      "params": {
