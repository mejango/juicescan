  "devdoc": {
    "addPriceFeedFor(uint256,uint256,uint256,address)": {
      "details": "Project ID 0 stores protocol defaults and can only be configured by this contract's owner. Non-zero project IDs can only be configured by that project's controller. The feed is stored only for the exact `pricingCurrency`/`unitCurrency` direction; the opposite direction is derived by `pricePerUnitOf` when needed. Later feeds for the same exact pair are backups. The existing feeds remain preferred, and this function rejects duplicate feed addresses for the exact pair.",
      "params": {
        "feed": "The price feed to add.",
        "pricingCurrency": "The currency that the feed's returned price is denominated in.",
        "projectId": "The ID of the project to add the feed for, or 0 to add a protocol default.",
        "unitCurrency": "The currency whose unit is priced by the feed."
      }
    },
    "constructor": {
      "params": {
        "directory": "A contract storing directories of terminals and controllers for each project.",
        "owner": "The address that will own the contract.",
        "permissions": "A contract storing permissions.",
        "projects": "A contract which mints ERC-721s that represent project ownership and transfers.",
        "trustedForwarder": "The trusted forwarder for the ERC2771Context."
      }
    },
    "isTrustedForwarder(address)": {
      "details": "Indicates whether any particular address is the trusted forwarder."
    },
    "owner()": {
      "details": "Returns the address of the current owner."
    },
    "priceFeedAt(uint256,uint256,uint256,uint256)": {
      "details": "This view does not apply inverse or project-default fallback lookup. It reverts with Solidity's default array bounds check if `index` is not configured.",
      "params": {
        "index": "The index of the feed to return.",
        "pricingCurrency": "The currency that the feed's returned price is denominated in.",
        "projectId": "The ID of the project whose feed should be returned.",
        "unitCurrency": "The currency whose unit is priced by the feed."
      },
      "returns": {
        "feed": "The configured price feed for the exact pair at `index`."
      }
    },
    "priceFeedCountFor(uint256,uint256,uint256)": {
      "details": "This count does not include feeds configured for the inverse direction or project ID 0 defaults.",
      "params": {
        "pricingCurrency": "The currency that the feeds' returned prices are denominated in.",
        "projectId": "The ID of the project whose feed count should be returned.",
        "unitCurrency": "The currency whose unit is priced by the feeds."
      },
      "returns": {
        "count": "The number of configured price feeds for the exact pair."
      }
    },
    "priceFeedFor(uint256,uint256,uint256)": {
      "details": "This view does not apply inverse or project-default fallback lookup. Use `pricePerUnitOf` to resolve a usable price through the full backup path.",
      "params": {
        "pricingCurrency": "The currency that the feed's returned price is denominated in.",
        "projectId": "The ID of the project whose primary feed should be returned.",
        "unitCurrency": "The currency whose unit is priced by the feed."
      },
      "returns": {
        "feed": "The first configured price feed for the exact pair, or the zero address if none exists."
      }
    },
    "pricePerUnitOf(uint256,uint256,uint256,uint256)": {
      "details": "Lookup order is project direct feeds, project inverse feeds, default direct feeds, then default inverse feeds. Each feed list is tried in registration order, skipping feeds that revert or return zero. Reverts with `JBPrices_PriceFeedNotFound` if no configured feed in that lookup path returns a non-zero price.",
      "params": {
        "decimals": "The number of decimals the returned fixed point price should use.",
        "pricingCurrency": "The currency that the returned price is denominated in.",
        "projectId": "The ID of the project to check first. Project ID 0 feeds are used as defaults.",
        "unitCurrency": "The currency whose unit is being priced."
      },
      "returns": {
        "price": "The `pricingCurrency` price of one `unitCurrency`, using `decimals` fixed point precision."
      }
    },
    "renounceOwnership()": {
      "details": "Leaves the contract without owner. It will not be possible to call `onlyOwner` functions. Can only be called by the current owner. NOTE: Renouncing ownership will leave the contract without an owner, thereby disabling any functionality that is only available to the owner."
    },
    "transferOwnership(address)": {
      "details": "Transfers ownership of the contract to a new account (`newOwner`). Can only be called by the current owner."
    },
    "trustedForwarder()": {
      "details": "Returns the address of the trusted forwarder."
    }
  },
