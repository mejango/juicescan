  "devdoc": {
    "constructor": {
      "params": {
        "baseProtocolProjectId": "The ID of the protocol project that will receive fees from fulfilling commitments.",
        "controller": "The controller to use to launch the game from.",
        "defifaProjectId": "The ID of the project that should take the fee from the games.",
        "governor": "The Defifa governor.",
        "hookCodeOrigin": "The code of the Defifa hook.",
        "hookStore": "The store used by Defifa hooks.",
        "registry": "The contract storing references to the deployer of each hook.",
        "tokenUriResolver": "The standard default token URI resolver."
      }
    },
    "currentGamePhaseOf(uint256)": {
      "details": "The game phase corresponds to the game's current funding cycle number.NO_CONTEST is returned if the minimum participation threshold is not met, or if the scorecard timeout has elapsed without ratification.",
      "params": {
        "gameId": "The ID of the game to get the phase number of."
      },
      "returns": {
        "_0": "The game phase."
      }
    },
    "currentGamePotOf(uint256,bool)": {
      "params": {
        "gameId": "The ID of the game for which the pot applies.",
        "includeCommitments": "A flag indicating if the portion of the pot committed to fulfill preprogrammed obligations should be included."
      },
      "returns": {
        "_0": "The game's pot amount, as a fixed point number.",
        "_1": "The token address the game's pot is measured in.",
        "_2": "The number of decimals included in the amount."
      }
    },
    "fulfillCommitmentsOf(uint256)": {
      "params": {
        "gameId": "The ID of the game to fulfill splits for."
      }
    },
    "launchGameWith((string,string,string,string,(string,uint16,address,bytes32,bool)[],uint104,(address,uint8,uint32),uint24,uint24,uint48,(uint32,uint64,address,bool,uint48,address)[],uint256,uint256,address,address,address,uint256,uint32,uint256))": {
      "details": "Forwards `msg.value` to `JBProjects.createFor` to cover any configured project creation fee.",
      "params": {
        "launchProjectData": "Data necessary to fulfill the transaction to launch a game."
      },
      "returns": {
        "gameId": "The ID of the newly configured game."
      }
    },
    "nextPhaseNeedsQueueing(uint256)": {
      "params": {
        "gameId": "The ID of the game to get the queue status of."
      },
      "returns": {
        "_0": "Whether or not the next phase still needs queuing."
      }
    },
    "safetyParamsOf(uint256)": {
      "params": {
        "gameId": "The ID of the game to get the safety params of."
      },
      "returns": {
        "minParticipation": "The minimum cumulative NFT mint cost for the game to proceed to scoring.",
        "scorecardTimeout": "The maximum time after scoring begins for a scorecard to be ratified."
      }
    },
    "timesFor(uint256)": {
      "params": {
        "gameId": "The ID of the game for which the game times apply."
      },
      "returns": {
        "_0": "The game's start time, as a unix timestamp.",
        "_1": "The game's minting period duration, in seconds.",
        "_2": "The game's refund period duration, in seconds."
      }
    },
    "tokenOf(uint256)": {
      "params": {
        "gameId": "The ID of the game to get the token of."
      },
      "returns": {
        "_0": "The game's token."
      }
    },
    "triggerNoContestFor(uint256)": {
      "details": "Anyone can call this once the game is in the NO_CONTEST phase. This queues a new ruleset without payout limits, making the surplus equal to the balance so users can cash out at their mint price.Analogous to fulfillCommitmentsOf for COMPLETE — must be called before NO_CONTEST cash-outs work.",
      "params": {
        "gameId": "The ID of the game to trigger no-contest for."
      }
    }
  },
  "userdoc": {
    "BASE_PROTOCOL_FEE_DIVISOR()": {
      "notice": "The divisor that describes the protocol fee that should be taken."
    },
    "BASE_PROTOCOL_PROJECT_ID()": {
      "notice": "The project ID that will receive protocol fees as commitments are fulfilled."
