    "setEnsNamePartsFor(uint256,uint256,string[])": {
      "details": "The `parts` [\"jbx\", \"dao\", \"foo\"] represents foo.dao.jbx.eth.Callers must provide ENS-normalized names (lowercase, ENSIP-15). ASCII control characters, DEL, and dots are rejected here; higher-byte Unicode (invisible codepoints like U+2060, the Tags block, etc.) is NOT filtered onchain because an onchain denylist cannot be complete and a partial one is a false safety signal. Clients must apply ENSIP-15 normalization off-chain before trusting a returned handle.",
      "params": {
        "chainId": "The chain ID of the network the project is on.",
        "parts": "The parts of the ENS domain to use as the project handle, excluding the trailing .eth.",
        "projectId": "The ID of the project to set an ENS handle for."
      }
    },
