  "devdoc": {
    "CLOCK_MODE()": {
      "details": "Machine-readable description of the clock as specified in ERC-6372."
    },
    "clock()": {
      "details": "Clock used for flagging checkpoints. Can be overridden to implement timestamp based checkpoints (and voting), in which case {CLOCK_MODE} should be overridden as well to match."
    },
    "constructor": {
      "details": "The implementation contract is initialized in the constructor to prevent direct use. Clones are initialized via `initialize()`.",
      "params": {
        "store": "The store that holds tier data for each hook's NFTs."
      }
    },
    "delegate(address)": {
      "details": "Delegates votes from the sender to `delegatee`."
    },
    "delegate(address,uint256[])": {
      "details": "Mint and transfer hooks normally write owner checkpoints automatically. The token ID list keeps pre-upgrade or otherwise uncheckpointed tokens recoverable while preserving the owner-only authorization check.",
      "params": {
        "delegatee": "The address to delegate voting power to. Use your own address for self-delegation.",
        "tokenIds": "The token IDs whose owner checkpoints should be backfilled if missing."
      }
    },
    "delegateBySig(address,uint256,uint256,uint8,bytes32,bytes32)": {
      "details": "Delegates votes from signer to `delegatee`."
    },
    "delegates(address)": {
      "details": "Returns the delegate that `account` has chosen."
    },
    "eip712Domain()": {
      "details": "returns the fields and values that describe the domain separator used by this contract for EIP-712 signature."
    },
    "getPastAccountTierActiveVotes(address,uint256,uint256)": {
      "details": "Counts only tier voting units held by `account` while `account` had a nonzero delegate.",
      "params": {
        "account": "The account to get the delegated tier voting units of.",
        "blockNumber": "The past block number to look up.",
        "tierId": "The tier to get the delegated voting units of."
      },
      "returns": {
        "activeVotes": "The account's delegated tier voting units at `blockNumber`."
      }
    },
    "getPastTierVotingUnits(uint256,uint256)": {
      "params": {
        "blockNumber": "The block number to look up (must be strictly in the past).",
        "tierId": "The tier to get the owner-checkpointed voting units of."
      },
      "returns": {
        "votingUnits": "The tier's owner-checkpointed voting units at `blockNumber`."
      }
    },
    "getPastTotalActiveVotes(uint256)": {
      "details": "This tracks delegated vote participation and is separate from tier reward eligibility.",
      "params": {
        "blockNumber": "The past block number to look up."
      },
      "returns": {
        "activeVotes": "The total voting units delegated to nonzero delegates at `blockNumber`."
      }
    },
    "getPastTotalSupply(uint256)": {
      "details": "Returns the total supply of votes available at a specific moment in the past. If the `clock()` is configured to use block numbers, this will return the value at the end of the corresponding block. NOTE: This value is the sum of all available votes, which is not necessarily the sum of all delegated votes. Votes that have not been delegated are still part of total supply, even though they would not participate in a vote. Requirements: - `timepoint` must be in the past. If operating using block numbers, the block must be already mined."
    },
    "getPastTotalTierActiveVotes(uint256,uint256)": {
      "details": "Counts only tier voting units held by accounts with a nonzero delegate.",
      "params": {
        "blockNumber": "The past block number to look up.",
        "tierId": "The tier to get the delegated voting units of."
      },
      "returns": {
        "activeVotes": "The tier's delegated voting units at `blockNumber`."
      }
    },
    "getPastVotes(address,uint256)": {
      "details": "Returns the amount of votes that `account` had at a specific moment in the past. If the `clock()` is configured to use block numbers, this will return the value at the end of the corresponding block. Requirements: - `timepoint` must be in the past. If operating using block numbers, the block must be already mined."
    },
    "getTotalActiveVotes()": {
      "details": "This tracks delegated vote participation and is separate from tier reward eligibility.",
      "returns": {
        "activeVotes": "The current total voting units delegated to nonzero delegates."
      }
    },
    "getTotalTierActiveVotes(uint256)": {
      "params": {
        "tierId": "The tier to get the current delegated voting units of."
      },
      "returns": {
        "activeVotes": "The tier's current delegated voting units."
      }
    },
    "getVotes(address)": {
      "details": "Returns the current amount of votes that `account` has."
    },
    "initialize(address)": {
      "details": "Can only be called once. Called by the deployer after cloning.",
      "params": {
        "hookAddress": "The hook this module serves."
      }
    },
    "nonces(address)": {
      "details": "Returns the next unused nonce for an address."
    },
    "onTransfer(address,address,uint256)": {
      "details": "Only callable by the hook. Looks up the token's tier voting units from the store.",
      "params": {
        "from": "The previous owner (address(0) on mint).",
        "to": "The new owner (address(0) on burn).",
        "tokenId": "The token ID to transfer."
      }
    },
    "ownerOfAt(uint256,uint256)": {
      "details": "Returns `address(0)` if no ownership checkpoint exists or the query predates the first checkpoint.",
      "params": {
        "blockNumber": "The block number to look up.",
        "tokenId": "The token ID of the NFT to get the historical owner of."
      },
      "returns": {
        "owner": "The owner of the token at `blockNumber`, or zero if no owner is proven at that block."
      }
    }
  },
