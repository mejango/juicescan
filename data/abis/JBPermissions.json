  "devdoc": {
    "constructor": {
      "params": {
        "trustedForwarder": "The trusted forwarder for the ERC2771Context."
      }
    },
    "hasPermission(address,address,uint256,uint256,bool,bool)": {
      "params": {
        "account": "The account that granted (or didn't grant) the permission.",
        "includeRoot": "If `true`, returns `true` immediately when the operator has the ROOT permission.",
        "includeWildcardProjectId": "If `true`, also checks wildcard (project 0) permissions as a fallback.",
        "operator": "The address to check.",
        "permissionId": "The specific permission ID to look for (0–255).",
        "projectId": "The project ID to check within. Pass 0 to check the wildcard scope directly."
      },
      "returns": {
        "_0": "Whether the operator holds the requested permission."
      }
    },
    "hasPermissions(address,address,uint256,uint256[],bool,bool)": {
      "params": {
        "account": "The account that granted (or didn't grant) the permissions.",
        "includeRoot": "If `true`, returns `true` immediately when the operator has the ROOT permission.",
        "includeWildcardProjectId": "If `true`, also checks wildcard (project 0) permissions as a fallback.",
        "operator": "The address to check permissions for.",
        "permissionIds": "The permission IDs that must all be present.",
        "projectId": "The project ID to check within. Pass 0 to check the wildcard scope directly."
      },
      "returns": {
        "_0": "Whether the operator holds every requested permission."
      }
    },
    "isTrustedForwarder(address)": {
      "details": "Indicates whether any particular address is the trusted forwarder."
    },
    "setPermissionsFor(address,(address,uint64,uint8[]))": {
      "details": "Only the account itself can set permissions without restriction. A ROOT operator on a specific project can set non-ROOT permissions for that same project on the account's behalf, but cannot grant ROOT or set wildcard (project ID 0) permissions — preventing privilege escalation.",
      "params": {
        "account": "The account to configure operator permissions for.",
        "permissionsData": "The operator address, project scope, and permission IDs to set."
      }
    },
    "trustedForwarder()": {
      "details": "Returns the address of the trusted forwarder."
    }
  },
  "userdoc": {
    "WILDCARD_PROJECT_ID()": {
      "notice": "Project ID 0 acts as a wildcard for permissions across all projects owned by the account."
    },
    "hasPermission(address,address,uint256,uint256,bool,bool)": {
      "notice": "Check whether an operator has a single permission for an account and project."
    },
    "hasPermissions(address,address,uint256,uint256[],bool,bool)": {
      "notice": "Check whether an operator has *all* of the specified permissions for an account and project."
    },
    "permissionsOf(address,address,uint256)": {
      "notice": "The packed permission bitmap that an account has granted to an operator for a specific project."
    },
    "setPermissionsFor(address,(address,uint64,uint8[]))": {
      "notice": "Grant or revoke permissions for an operator on a specific project."
    }
  },
  "contractName": "JBPermissions",
  "sourceName": "node_modules/@bananapus/core-v6/src/JBPermissions.sol",
  "contractNotice": "The permission system for Juicebox. Any address can authorize another address (an \"operator\") to perform specific actions on its behalf — like queuing rulesets, distributing payouts, or managing terminals."
}
